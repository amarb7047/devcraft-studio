rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }
    
    // Helper to check if user is the admin (Amar Biswas)
    function isAdmin() {
      return isAuth() && (
        request.auth.token.email == 'amar@devcraft.studio' || 
        request.auth.token.email == '7047310066@paytm' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
    
    // Helper to check if the document belongs to the logged-in user
    isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Users Collection rules
    match /users/{userId} {
      allow read: if isAuth() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Orders Collection rules
    match /orders/{orderId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && (
        isAdmin() || 
        // Client can only update if they own the order AND only modifying specific fields (like submitting UPI UTR)
        (resource.data.userId == request.auth.uid && 
         request.resource.data.userId == request.auth.uid &&
         request.resource.data.status == resource.data.status && // Client cannot change status
         request.resource.data.price == resource.data.price // Client cannot change price
        )
      );
      allow delete: if isAdmin();
    }

    // Invoices Collection rules
    match /invoices/{invoiceId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Chats Collection rules
    match /chats/{chatId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth() && (
        (request.resource.data.userId == request.auth.uid && request.resource.data.sender == 'client') || 
        isAdmin()
      );
      allow update: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Portfolio Collection rules
    match /portfolio/{projectId} {
      allow read: if resource.data.isVisible == true || isAdmin();
      allow write: if isAdmin();
    }

    // Settings Collection rules
    match /settings/{settingId} {
      allow read: if true; // Public contact info and UPI IDs must be readable by clients
      allow write: if isAdmin();
    }
  }
}
